# 前端 API 基础地址（默认 https://ukamnads.icu）
VITE_API_BASE=https://ukamnads.icu

# 可选：手动覆盖 UserHub 地址；默认由 VITE_API_BASE 推导 /api/v2/user-hub
# VITE_SIGNALR_URL=https://ukamnads.icu/api/v2/user-hub

# 冒烟/契约脚本环境变量示例（按需导出，不建议写入 .env）
# DANMAKUS_API_BASE=https://ukamnads.icu
# DANMAKUS_TOKEN=your_account_token
# DANMAKUS_ROOM_ID=123456
