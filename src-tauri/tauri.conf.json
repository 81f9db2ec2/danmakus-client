{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "danmakus-client",
  "version": "0.2.5",
  "identifier": "com.danmakus.client",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "danmakus-client",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: wss:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzRDc3QjZEN0Y0Nzc0ODkKUldTSmRFZC9iWHZYMDI1WjFobFlVZmJDR2QrUVlodXNpZWlGaExRdFl0UWEyK1l3eDl2T2NBVnoK",
      "endpoints": [
        "https://tauri-update-server.81f9db2ec2.workers.dev/v1/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
